<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.0.0">
  
  <bpmn:process id="order-processing" name="Food Order Processing Workflow" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderPlaced" name="Order Placed">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_OrderPlaced" targetRef="ServiceTask_ProcessPayment" />
    
    <bpmn:serviceTask id="ServiceTask_ProcessPayment" name="Process Payment" camunda:asyncBefore="true" camunda:delegateExpression="${processPaymentDelegate}">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:sequenceFlow id="Flow_2" sourceRef="ServiceTask_ProcessPayment" targetRef="Gateway_PaymentCheck" />
    
    <bpmn:exclusiveGateway id="Gateway_PaymentCheck" name="Payment Successful?" default="Flow_Failed">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Success</bpmn:outgoing>
      <bpmn:outgoing>Flow_Failed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:sequenceFlow id="Flow_Success" name="Yes" sourceRef="Gateway_PaymentCheck" targetRef="ServiceTask_SendToKitchen">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentSuccess == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:sequenceFlow id="Flow_Failed" name="No" sourceRef="Gateway_PaymentCheck" targetRef="ServiceTask_CancelOrder" />
    
    <bpmn:serviceTask id="ServiceTask_CancelOrder" name="Cancel Order" camunda:delegateExpression="${cancelOrderDelegate}">
      <bpmn:incoming>Flow_Failed</bpmn:incoming>
      <bpmn:outgoing>Flow_EndCancelled</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:sequenceFlow id="Flow_EndCancelled" sourceRef="ServiceTask_CancelOrder" targetRef="EndEvent_OrderCancelled" />
    
    <bpmn:endEvent id="EndEvent_OrderCancelled" name="Order Cancelled">
      <bpmn:incoming>Flow_EndCancelled</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:serviceTask id="ServiceTask_SendToKitchen" name="Send To Kitchen" camunda:asyncBefore="true" camunda:delegateExpression="${sendToKitchenDelegate}">
      <bpmn:incoming>Flow_Success</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:sequenceFlow id="Flow_4" sourceRef="ServiceTask_SendToKitchen" targetRef="ServiceTask_RequestDelivery" />
    
    <bpmn:serviceTask id="ServiceTask_RequestDelivery" name="Request Delivery" camunda:asyncBefore="true" camunda:delegateExpression="${requestDeliveryDelegate}">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:sequenceFlow id="Flow_5" sourceRef="ServiceTask_RequestDelivery" targetRef="EndEvent_OrderCompleted" />
    
    <bpmn:endEvent id="EndEvent_OrderCompleted" name="Order Completed">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="order-processing">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_OrderPlaced">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="138" y="145" width="65" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0mxhv43_di" bpmnElement="ServiceTask_ProcessPayment">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PaymentCheck_di" bpmnElement="Gateway_PaymentCheck" isMarkerVisible="true">
        <dc:Bounds x="395" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="391" y="65" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1y2z1w5_di" bpmnElement="ServiceTask_CancelOrder">
        <dc:Bounds x="500" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0209hpx_di" bpmnElement="EndEvent_OrderCancelled">
        <dc:Bounds x="662" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="640" y="265" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_05yru3e_di" bpmnElement="ServiceTask_SendToKitchen">
        <dc:Bounds x="500" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0p2t7w7_di" bpmnElement="ServiceTask_RequestDelivery">
        <dc:Bounds x="650" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1gsp30z_di" bpmnElement="EndEvent_OrderCompleted">
        <dc:Bounds x="802" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="778" y="145" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="240" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="120" />
        <di:waypoint x="395" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Success_di" bpmnElement="Flow_Success">
        <di:waypoint x="445" y="120" />
        <di:waypoint x="500" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="464" y="102" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Failed_di" bpmnElement="Flow_Failed">
        <di:waypoint x="420" y="145" />
        <di:waypoint x="420" y="240" />
        <di:waypoint x="500" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="428" y="190" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndCancelled_di" bpmnElement="Flow_EndCancelled">
        <di:waypoint x="600" y="240" />
        <di:waypoint x="662" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="600" y="120" />
        <di:waypoint x="650" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="750" y="120" />
        <di:waypoint x="802" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
